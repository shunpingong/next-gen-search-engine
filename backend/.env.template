# Ghost Network API Environment Configuration

# GitHub API (Required for Linux Kernel Security domain)
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# NVD API (Optional - improves rate limits)
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# PubMed/NCBI (Required for Healthcare domain)
# Provide your email for NCBI E-utilities
PUBMED_EMAIL=your-email@example.com

# Local LLM Configuration (Optional)
# Uncomment and configure if using local LLM
# LLM_MODEL=llama2
# LLM_API_URL=http://localhost:11434  # For Ollama
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=2000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Graph Analysis Configuration
PAGERANK_DAMPING=0.85
PAGERANK_MAX_ITER=100
PAGERANK_TOLERANCE=0.000001

# Logging
LOG_LEVEL=INFO
