# TAG Search Engine API Environment Configuration

# ============================================================================
# Required API Keys
# ============================================================================

# OpenAI API
# Used for LLM access (GPT-4, GPT-3.5, etc.) via OpenAI
# Get your API key at: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# TextGrad model configuration
TEXTGRAD_BACKWARD_MODEL=gpt-4o
TEXTGRAD_ADVANCED_MODEL=gpt-4o

# Tavily API
# Used for web search functionality
# Get your API key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# API Keys for different search/scraping services
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id_here
TAVILY_API_KEY=your_tavily_api_key_here
SERPER_API_KEY=your_serper_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
