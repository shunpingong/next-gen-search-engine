# TAG Search Engine API Environment Configuration

# ============================================================================
# Required API Keys
# ============================================================================

# OpenAI API
# Used for LLM access (GPT-4, GPT-3.5, etc.) via OpenAI
# Get your API key at: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# TextGrad model configuration
TEXTGRAD_BACKWARD_MODEL=gpt-4o
TEXTGRAD_ADVANCED_MODEL=gpt-4o

# Tavily API
# Used for web search functionality
# Get your API key at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_ENDPOINT=https://api.tavily.com/search

# Tavily retrieval pipeline tuning
TAVILY_PIPELINE_MODE=auto
TAVILY_USE_LLM_DECOMPOSITION=1
TAVILY_DECOMPOSITION_MODEL=gpt-5-mini
TAVILY_DECOMPOSITION_TIMEOUT_SECONDS=30
TAVILY_DECOMPOSITION_MAX_ATTEMPTS=2
TAVILY_USE_FOLLOW_UP_RETRIEVAL=1
TAVILY_USE_LLM_FOLLOW_UP=1
TAVILY_FOLLOW_UP_MODEL=gpt-5-mini
TAVILY_FOLLOW_UP_TIMEOUT_SECONDS=30
TAVILY_FOLLOW_UP_SOURCE_DOC_COUNT=4
TAVILY_RERANKER_BACKEND=auto
TAVILY_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
TAVILY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TAVILY_ANSWER_MODEL=gpt-5-mini
TAVILY_ANSWER_TIMEOUT_SECONDS=30
TAVILY_MAX_ITERATIONS=2
TAVILY_BROWSECOMP_MAX_ITERATIONS=3
TAVILY_MAX_SEARCH_TASKS_PER_ITERATION=6
TAVILY_MAX_FETCH_TASKS_PER_ITERATION=8
TAVILY_MAX_ANSWER_DOCUMENTS=6
TAVILY_MAX_BROWSECOMP_PIVOT_DOCUMENTS=4
TAVILY_MAX_BROWSECOMP_LINK_CANDIDATES=6
TAVILY_MIN_BROWSECOMP_LINK_SCORE=0.42
TAVILY_FETCH_TIMEOUT_SECONDS=20
SEARCH_PROVIDER_ORDER=tavily,serper,serpapi,google_custom_search,duckduckgo
SEARCH_PROVIDER_STRATEGY=fallback
SEARCH_PROVIDER_QUOTA_COOLDOWN_SECONDS=3600
SEARCH_PROVIDER_FAILURE_COOLDOWN_SECONDS=300
SEARCH_SELENIUM_ENGINE=google

# API Keys for different search/scraping services
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id_here
SERPER_API_KEY=your_serper_api_key_here
SERPAPI_API_KEY=your_serpapi_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
